# Copy to .env and fill in. NEVER commit .env.
# Each team member has their own keys - do not share.

# === LLM ===
GEMINI_API_KEY=your_gemini_key_here

# === Reddit (PRAW) ===
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=neu-compass/0.1 by your_username

# === Google OAuth (Week 6) ===
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501/oauth/callback

# === Storage paths ===
# WSL2 推荐路径（性能更好）
SQLITE_PATH=./data/courses.db
FAISS_INDEX_PATH=./data/faiss_index

# === Embedding ===
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === API budget alarm (USD/month) ===
API_BUDGET_ALARM=150
