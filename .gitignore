# Secrets - NEVER commit
.env
*.env
!.env.example
*.key
*.pem
credentials.json
service_account*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
build/
dist/

# Virtual envs
.venv/
venv/
env/
.python-version

# uv: COMMIT uv.lock (reproducible builds across team / CI / WSL).
# Ignore only the venv itself.
# uv.lock is committed

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Project data (NEVER commit raw scraped data or PII)
data/raw/
data/processed/
data/coop_seed/*
!data/coop_seed/.gitkeep
!data/coop_seed/template.example.json
data/ground_truth/*.json
!data/ground_truth/.gitkeep

# Databases & indexes
*.db
*.db-journal
*.db-wal
*.db-shm
*.faiss
*.idx
faiss_index/

# Logs
*.log
logs/

# Backups
backups/
*.bak

# Streamlit
.streamlit/secrets.toml

# v3.1 stack launcher: transient PID file written by scripts/start_stack.ps1
# and consumed by scripts/stop_stack.ps1 — never commit (PIDs are per-session).
scripts/.stack_pids

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
*.tmp
*~
data/doc_expansion/
